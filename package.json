{
  "name": "make-stylelint",
  "version": "0.1.0",
  "type": "module",
  "funding": "https://github.com/sponsors/Jaid",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Jaid/make-stylelint.git"
  },
  "exports": {
    ".": {
      "default": "./src/main.ts"
    }
  },
  "imports": {
