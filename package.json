    "#root/*": "./*"
  },
  "scripts": {
    "test": "bun test --max-concurrency 1 ./test"
  },
  "dependencies": {
    "es-toolkit": "^1.46.1",
    "optis": "^0.1.0"
  },
  "peerDependencies": {
    "postcss-sass": "^0.5.0",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17",
    "stylelint-scss": "^7.1.1"
  },
  "peerDependenciesMeta": {
    "postcss-sass": {
      "optional": true
    },
    "postcss-scss": {
      "optional": true
    },
    "stylelint-scss": {
      "optional": true
    }
  },
  "devDependencies": {
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-jaid": "^26.0.0",
    "tsconfig-jaid-bun": "^15.2.0",
    "type-fest": "^5.6.0",
    "typescript": "^6.0.3"
  }
}